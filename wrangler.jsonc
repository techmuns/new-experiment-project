{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "memoupdater",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,

  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  // ---------------------------------------------------------------
  // Phase 4A/4B/4C/4D/5: LLM follow-up memo + OpenAI research.
  //
  // LLM_ENABLED="true" turns on the server-side LLM path. It does
  // NOT by itself authorize anyone to spend provider tokens.
  //
  // LLM_PROVIDER selects the provider implementation:
  //   "openai"    — default; calls api.openai.com/v1/responses with
  //                 strict json_schema. POST /api/research/updates
  //                 additionally enables the built-in web_search
  //                 tool for source-grounded research.
  //   "anthropic" — calls api.anthropic.com/v1/messages with
  //                 tool_use; remains fully supported for the memo
  //                 generation path. The research endpoint requires
  //                 OpenAI and returns research_unavailable for
  //                 other providers.
  // LLM_MODEL is the model id passed to the selected provider
  // (e.g. "gpt-5.2" for OpenAI, "claude-sonnet-4-6" for Anthropic).
  //
  // API key secrets — preferred and fallback:
  //   wrangler secret put LLM_API_KEY      # preferred (any provider)
  //   wrangler secret put OPENAI_API_KEY   # fallback, OpenAI ONLY
  // The Worker prefers LLM_API_KEY when present. When LLM_PROVIDER
  // is "openai" and LLM_API_KEY is absent, it falls back to
  // OPENAI_API_KEY so a Cloudflare secret already provisioned under
  // that name keeps working. Anthropic always reads LLM_API_KEY.
  // /api/llm/status surfaces apiKeySource as
  //   "LLM_API_KEY" | "OPENAI_API_KEY" | "none"
  // so Settings can show which secret is in use without leaking it.
  //
  // /api/llm/status reports llmReady:true only when all four hold:
  // LLM_ENABLED="true", provider configured, API key configured
  // (either name), and (gate disabled OR gate secret configured).
  // researchAvailable:true requires the above AND provider="openai".
  //
  // App-level access gate (LLM_GATE_ENABLED, default "true"):
  //   Default is "true" because this repo has no real auth, no
  //   Cloudflare Access config, and no rate limiting. The gate
  //   prevents anonymous abuse of the provider key while you set
  //   up real controls. When enabled, generate AND research must
  //   carry a valid X-Memo-LLM-Gate header (constant-time compare
  //   in src/worker/llm/provider.ts::checkGateToken). Rejected
  //   requests return HTTP 200 {ok:false, code:"llm_access_denied"}
  //   and short-circuit before any provider call, so they cost
  //   nothing on the provider side.
  //
  //   Operators can set LLM_GATE_ENABLED="false" in this file AFTER
  //   configuring Cloudflare Access / WAF / IP allowlist / rate
  //   limiting. That is a deliberate hardening step, out-of-band,
  //   not a repo default. The main Workspace UI never renders a
  //   passcode input; Settings exposes the internal token under a
  //   collapsed "Advanced" section for internal testing.
  //
  // NO SECRET VALUES ARE COMMITTED. All `wrangler secret put`
  // commands above are the operator's job; the values must never
  // appear in this file, .dev.vars, .env, or any tracked source.
  //
  // Cloudflare Access / WAF / IP allowlist / rate limiting is
  // RECOMMENDED in the Cloudflare dashboard before any non-internal
  // use. The shared in-app gate token is a cost-spend deterrent;
  // it is NOT a substitute for real auth or rate limiting.
  // ---------------------------------------------------------------
  "vars": {
    "LLM_ENABLED": "true",
    "LLM_PROVIDER": "openai",
    "LLM_MODEL": "gpt-5.2",
    "LLM_GATE_ENABLED": "true"
  }

  // ---------------------------------------------------------------
  // Phase 2+ placeholders. Uncomment, then run `npm run cf-typegen`.
  // ---------------------------------------------------------------
  //
  // "vars": {
  //   "ENVIRONMENT": "production"
  // },
  //
  // R2: store uploaded memos, financial PDFs, transcripts
  // "r2_buckets": [
  //   { "binding": "MEMO_UPLOADS", "bucket_name": "memo-updater-uploads" }
  // ],
  //
  // D1: persist projects, MemoDNA extractions, generation runs
  // "d1_databases": [
  //   {
  //     "binding": "DB",
  //     "database_name": "memo-updater-db",
  //     "database_id": "REPLACE_ME"
  //   }
  // ],
  //
  // Queues: async LLM extraction / generation pipeline
  // "queues": {
  //   "producers": [
  //     { "binding": "MEMO_QUEUE", "queue": "memo-jobs" }
  //   ],
  //   "consumers": [
  //     { "queue": "memo-jobs", "max_batch_size": 1 }
  //   ]
  // },
  //
  // Workflows: durable multi-step memo generation
  // "workflows": [
  //   {
  //     "binding": "MEMO_WORKFLOW",
  //     "name": "memo-workflow",
  //     "class_name": "MemoWorkflow"
  //   }
  // ]
  //
  // Secrets (set with `wrangler secret put`, never committed):
  //   ANTHROPIC_API_KEY
  //   OPENAI_API_KEY
}
