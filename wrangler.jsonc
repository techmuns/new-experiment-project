{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "memoupdater",
  "main": "./src/worker/index.ts",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,

  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  // ---------------------------------------------------------------
  // Phase 4A/4B/4C/4D: LLM follow-up memo generation.
  //
  // LLM_ENABLED="true" turns on the server-side LLM path. It does
  // NOT by itself authorize anyone to spend provider tokens.
  //
  // LLM_PROVIDER selects the provider implementation:
  //   "openai"    — default; calls api.openai.com/v1/responses
  //                 with structured-output json_schema (strict).
  //   "anthropic" — calls api.anthropic.com/v1/messages with
  //                 tool_use; remains fully supported.
  // LLM_MODEL is the model id passed to the selected provider
  // (e.g. "gpt-5.2" for OpenAI, "claude-sonnet-4-6" for Anthropic).
  //
  // LLM_API_KEY MUST match the configured provider:
  //   - LLM_PROVIDER="openai"    -> set LLM_API_KEY to an OpenAI key
  //   - LLM_PROVIDER="anthropic" -> set LLM_API_KEY to an Anthropic key
  // Single env var; the provider decides how to use it.
  //
  // LLM Memo v1 is still NOT ready unless BOTH of these secrets are
  // set out-of-band against the deployed Worker (never committed):
  //   wrangler secret put LLM_API_KEY      # provider key
  //   wrangler secret put LLM_GATE_SECRET  # shared in-app gate token
  // /api/llm/status reports llmReady:true only when all four hold:
  // LLM_ENABLED="true", provider configured, API key configured,
  // and (gate disabled OR gate secret configured).
  //
  // With LLM_GATE_ENABLED="true" the Worker MUST still reject
  // /api/generate/follow-up-memo unless the gate secret is set AND
  // the request carries a valid X-Memo-LLM-Gate header (constant-
  // time compare in src/worker/llm/provider.ts::checkGateToken).
  // Rejected requests return HTTP 200 {ok:false, code:
  // "llm_access_denied"} and short-circuit before any provider
  // call, so they cost nothing on the provider side. The client
  // falls back to the deterministic v0 generator.
  //
  // NO SECRET VALUES ARE COMMITTED. The two `wrangler secret put`
  // commands above are the operator's job; the values must never
  // appear in this file, .dev.vars, .env, or any tracked source.
  //
  // Cloudflare Access / WAF / IP allowlist / rate limiting is
  // RECOMMENDED in the Cloudflare dashboard before any non-internal
  // use. The shared in-app gate token is a cost-spend deterrent for
  // uninformed visitors; it is NOT a substitute for real auth or
  // rate limiting.
  // ---------------------------------------------------------------
  "vars": {
    "LLM_ENABLED": "true",
    "LLM_PROVIDER": "openai",
    "LLM_MODEL": "gpt-5.2",
    "LLM_GATE_ENABLED": "true"
  }

  // ---------------------------------------------------------------
  // Phase 2+ placeholders. Uncomment, then run `npm run cf-typegen`.
  // ---------------------------------------------------------------
  //
  // "vars": {
  //   "ENVIRONMENT": "production"
  // },
  //
  // R2: store uploaded memos, financial PDFs, transcripts
  // "r2_buckets": [
  //   { "binding": "MEMO_UPLOADS", "bucket_name": "memo-updater-uploads" }
  // ],
  //
  // D1: persist projects, MemoDNA extractions, generation runs
  // "d1_databases": [
  //   {
  //     "binding": "DB",
  //     "database_name": "memo-updater-db",
  //     "database_id": "REPLACE_ME"
  //   }
  // ],
  //
  // Queues: async LLM extraction / generation pipeline
  // "queues": {
  //   "producers": [
  //     { "binding": "MEMO_QUEUE", "queue": "memo-jobs" }
  //   ],
  //   "consumers": [
  //     { "queue": "memo-jobs", "max_batch_size": 1 }
  //   ]
  // },
  //
  // Workflows: durable multi-step memo generation
  // "workflows": [
  //   {
  //     "binding": "MEMO_WORKFLOW",
  //     "name": "memo-workflow",
  //     "class_name": "MemoWorkflow"
  //   }
  // ]
  //
  // Secrets (set with `wrangler secret put`, never committed):
  //   ANTHROPIC_API_KEY
  //   OPENAI_API_KEY
}
